# ============================================================
# CuePoint — root env (copied/referenced by apps & packages)
# Copy this file to .env and adjust as needed
# ============================================================

# Node
NODE_ENV=development

# Database
DATABASE_URL=postgresql://cuepoint:cuepoint_dev@localhost:5433/cuepoint

# Redis
REDIS_URL=redis://localhost:16379

# Object storage (MinIO locally, S3/R2 in prod)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=cuepoint
S3_ACCESS_KEY=cuepoint
S3_SECRET_KEY=cuepoint_dev_secret
S3_FORCE_PATH_STYLE=true

# API
API_PORT=4000
API_HOST=0.0.0.0
API_BASE_URL=http://localhost:4000
WEB_BASE_URL=http://localhost:5173

# Auth
AUTH_SECRET=change_me_to_a_long_random_string_at_least_32_chars
SESSION_COOKIE_NAME=cuepoint_session

# CORS
CORS_ORIGIN=http://localhost:5173

# Email (Resend) — get a free API key at resend.com
# Leave blank to disable email sending in dev (invite link still shown in UI)
RESEND_API_KEY=
RESEND_FROM=invites@yourdomain.com
