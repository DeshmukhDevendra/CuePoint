{
  "name": "@cuepoint/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "node ./scripts/prisma-prepare-generate.mjs && prisma generate",
    "generate:noclean": "prisma generate",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src prisma scripts",
    "test": "echo 'db: no tests'",
    "clean": "rm -rf node_modules .turbo"
  },
  "dependencies": {
    "@node-rs/argon2": "^1.8.3",
    "@prisma/client": "^5.20.0"
  },
  "devDependencies": {
    "@cuepoint/tsconfig": "workspace:*",
    "@types/node": "^20.16.11",
    "prisma": "^5.20.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
