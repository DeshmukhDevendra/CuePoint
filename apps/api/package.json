{
  "name": "@cuepoint/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf node_modules dist .turbo"
  },
  "dependencies": {
    "@cuepoint/db": "workspace:*",
    "@cuepoint/shared": "workspace:*",
    "@lucia-auth/adapter-prisma": "^4.0.1",
    "@node-rs/argon2": "^1.8.3",
    "@socket.io/redis-adapter": "^8.3.0",
    "bullmq": "^5.73.4",
    "cookie": "^0.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.2",
    "ioredis": "^5.4.1",
    "lucia": "^3.2.0",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^4.3.1",
    "resend": "^6.10.0",
    "socket.io": "^4.8.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cuepoint/tsconfig": "workspace:*",
    "@types/cookie": "^0.6.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.16.11",
    "@types/qrcode": "^1.5.5",
    "@types/supertest": "^6.0.2",
    "pino-pretty": "^13.0.0",
